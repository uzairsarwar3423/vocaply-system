# Required — must be set to real values
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here

# Internal service auth — Node.js → Python shared secret
# Must be >= 32 chars in production. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_SHARED_SECRET=your-internal-shared-secret-min-32-chars

# Database connections
MONGODB_URL=mongodb://localhost:27017
REDIS_URL=redis://localhost:6379

# Optional — override defaults
ENVIRONMENT=development
LOG_LEVEL=INFO
PORT=8001

# Model names — change here to switch models without code deploy
GEMINI_FLASH_MODEL_NAME=gemini-2.0-flash
GEMINI_FLASH_LITE_MODEL_NAME=gemini-2.0-flash-lite
GEMINI_EMBEDDING_MODEL_NAME=text-embedding-004

# Resilience knobs
MAX_GEMINI_RETRIES=3
GEMINI_TIMEOUT_SECONDS=30.0
GEMINI_MAX_CONCURRENT_CALLS=10

# MongoDB pool sizing (pool_min_size × replica_count + pool_max_size × replica_count
# must stay under MongoDB Atlas / self-hosted connection ceiling)
MONGO_POOL_MIN_SIZE=2
MONGO_POOL_MAX_SIZE=20

# Redis pool sizing
REDIS_POOL_MAX_CONNECTIONS=20

# Node.js API origin for CORS scoping (non-production only)
NODE_API_INTERNAL_ORIGIN=http://localhost:5000

# MongoDB database name
MONGODB_DATABASE=vocaply
